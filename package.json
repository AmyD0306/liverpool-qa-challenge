{
  "name": "liverpool-qa-challenge",
  "version": "1.0.0",
  "description": "Cypress technical challenge for Liverpool product search flow.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "report:merge": "mochawesome-merge cypress/reports/mochawesome/*.json > cypress/reports/report.json",
    "report:html": "marge cypress/reports/report.json --reportDir cypress/reports/html --reportFilename index",
    "test:ci": "npm run cy:run && npm run report:merge && npm run report:html"
  },
  "keywords": [
    "cypress",
    "qa",
    "automation",
    "liverpool"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cypress": "^15.16.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}